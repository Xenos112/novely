{
  "name": "novel",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "go:build": "cd go && go build ./...",
    "go:fmt": "gofmt -w ./go",
    "go:lint": "cd go && golangci-lint run ./...",
    "go:release": "cd go && go run golang.org/x/mobile/cmd/gomobile bind -target=android -o scraper.aar ./sources && cp scraper.aar ../android/app/libs/",
    "go:test": "cd go && go test -v ./tests/... -count=1",
    "ios": "expo run:ios",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "start": "expo start",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.28",
    "@rn-primitives/label": "^1.2.0",
    "@rn-primitives/portal": "^1.3.0",
    "@rn-primitives/separator": "^1.2.0",
    "@rn-primitives/slot": "^1.2.0",
    "@rn-primitives/switch": "^1.2.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~55.0.6",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.6",
    "expo-keep-awake": "~55.0.4",
    "expo-key-event": "^1.8.3",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.9",
    "jotai": "^2.18.1",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.11",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint"
  }
}
